# Copie para .env.local (dev) ou configure no painel do Vercel (produção).
#
# EXPO_PUBLIC_* são embutidas no bundle em BUILD TIME — no Vercel, defina-as
# em Project → Settings → Environment Variables ANTES de fazer o deploy.

# URL da API, COM o sufixo /api.
#   Local:     http://127.0.0.1:8000/api
#   Produção:  https://clinica-api.onrender.com/api
EXPO_PUBLIC_API_URL=

# URL do WebSocket do chat, COM o caminho /ws/chat e esquema wss:// em produção.
#   Local:     ws://127.0.0.1:8000/ws/chat
#   Produção:  wss://clinica-api.onrender.com/ws/chat
EXPO_PUBLIC_WS_URL=
